# ── LLM Provider ──────────────────────────────────────────────────────────────
LLM_PROVIDER=openai                   # "openai" or "google"
LLM_MODEL=gpt-4o
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...

# ── LangSmith Observability (optional) ────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=hiring-ai

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=hiring_user
POSTGRES_PASSWORD=hiring_pass
POSTGRES_DB=hiring_ai
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://hiring_user:hiring_pass@localhost:5432/hiring_ai
DATABASE_URL_SYNC=postgresql://hiring_user:hiring_pass@localhost:5432/hiring_ai

# ── Redis (Celery broker + result backend) ────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_BACKEND=smtp                    # "smtp" or "gmail"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password
HR_EMAIL=hr@yourcompany.com
FROM_EMAIL=noreply@yourcompany.com

# ── Google Calendar ───────────────────────────────────────────────────────────
GOOGLE_CREDENTIALS_PATH=./config/google_credentials.json
GOOGLE_CALENDAR_ID=primary

# ── Pipeline Thresholds ────────────────────────────────────────────────────────
MAX_JD_REVISIONS=5
MAX_REPOST_ATTEMPTS=3
SHORTLIST_TOP_N=5
RESUME_SCORE_THRESHOLD=65
RESUME_INTAKE_DIR=./data/resumes/

# ── API ────────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=change-me-in-production
